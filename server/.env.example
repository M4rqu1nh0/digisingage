# ===== Configuracion del Servidor Admin Central (MULTI-TENANT) =====

# Entorno: en "production" el server NO arranca si JWT_SECRET o SUPERADMIN_PASS
# siguen con su valor por defecto, y la cookie de sesion se marca como Secure.
NODE_ENV=production

# Puerto en el que escucha el servidor Express
PORT=4000

# --- Super-administrador global ---
# Se crea automaticamente en el primer arranque si no existe.
# Gestiona empresas y sus usuarios admin (login con el campo "Empresa" vacio).
SUPERADMIN_USER=superadmin
SUPERADMIN_PASS=cambia_esta_clave_de_superadmin

# --- Empresa "Default" (solo migracion de datos antiguos) ---
# Si la BD trae dispositivos/medios del esquema anterior, se migran a una
# empresa "Default" y se crea su admin con estas credenciales.
ADMIN_USER=admin
ADMIN_PASS=admin123

# Secreto para firmar los tokens JWT (usar un valor largo y aleatorio)
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio

# Tiempo de vida de la sesion del admin
JWT_EXPIRES=8h

# Minutos de tolerancia para considerar un dispositivo "En Linea"
ONLINE_WINDOW_MIN=3

# Tamano maximo permitido por archivo al subir desde el panel (en MB)
MAX_UPLOAD_MB=500

# --- Rutas de almacenamiento (opcional) ---
# Utiles para apuntar a un disco persistente (p. ej. en Render) y no perder
# datos entre despliegues. Si se omiten, se usan carpetas junto al server.
# DB_PATH=/var/data/signage.db
# MEDIA_DIR=/var/data/media
# IMAGES_DIR=/var/data/images
