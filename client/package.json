{
  "name": "digisignage-client",
  "version": "1.0.0",
  "description": "Cliente standalone (Electron) para pantalla de carteleria",
  "author": "DigiSignage",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.digisignage.client",
    "productName": "DigiSignage",
    "directories": { "output": "dist" },
    "files": [
      "main.js",
      "preload.js",
      "player.html",
      "config.template.json"
    ],
    "win": { "target": "dir", "signAndEditExecutable": false }
  }
}
